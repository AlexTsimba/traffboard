      "checkConstraints": {
        "chk_traffic_positive_metrics": {
          "name": "chk_traffic_positive_metrics",
          "value": "\n        \"traffic_reports\".\"all_clicks\" >= 0 AND \n        \"traffic_reports\".\"unique_clicks\" >= 0 AND \n        \"traffic_reports\".\"registrations_count\" >= 0 AND \n        \"traffic_reports\".\"ftd_count\" >= 0 AND \n        \"traffic_reports\".\"deposits_count\" >= 0\n      "
        },
        "chk_traffic_rate_bounds": {
          "name": "chk_traffic_rate_bounds",
          "value": "\n        \"traffic_reports\".\"cr\" >= 0 AND \"traffic_reports\".\"cr\" <= 100 AND\n        \"traffic_reports\".\"cftd\" >= 0 AND \"traffic_reports\".\"cftd\" <= 100 AND\n        \"traffic_reports\".\"cd\" >= 0 AND \"traffic_reports\".\"cd\" <= 100 AND\n        \"traffic_reports\".\"rftd\" >= 0 AND \"traffic_reports\".\"rftd\" <= 100\n      "
        },
        "chk_traffic_click_logic": {
          "name": "chk_traffic_click_logic",
          "value": "\"traffic_reports\".\"unique_clicks\" <= \"traffic_reports\".\"all_clicks\""
        },
        "chk_traffic_device_type": {
          "name": "chk_traffic_device_type",
          "value": "\n        \"traffic_reports\".\"device_type\" IS NULL OR \n        \"traffic_reports\".\"device_type\" IN ('Phone', 'Desktop', 'Tablet', 'Computer')\n      "
        }
      },
