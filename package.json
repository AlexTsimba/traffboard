{
  "name": "traffboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:clean": "rm -rf tests/results tests/test-results playwright-report test-results",
    "typecheck": "tsc --noEmit",
    "commitlint": "commitlint --edit",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD --verbose",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "backup": "scripts/backup-local.sh",
    "backup:clean": "ls -t backups/*.tar.gz 2>/dev/null | tail -n +6 | xargs rm -f || echo 'No old backups to clean'",
    "setup:branch-protection": "node .github/branch-protection/setup-branch-protection.js",
    "setup:branch-protection:dry-run": "node .github/branch-protection/setup-branch-protection.js --dry-run",
    "setup:branch-protection:force": "node .github/branch-protection/setup-branch-protection.js --force"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "{src,app,components,lib,utils,hooks,pages}/**/*.{js,ts,jsx,tsx}": [
      "eslint --fix"
    ]
  },
