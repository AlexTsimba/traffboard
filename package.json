    "playwright": "^1.53.2",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.5",
    "ts-node": "^10.9.2",
